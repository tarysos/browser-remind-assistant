{
  "manifest_version": 3,
  "name": "Browser Reminder Assistant",
  "version": "1.0.0",
  "description": "瀏覽器工作流中的輕量提醒助手",
  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "tabs",
    "activeTab"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Browser Reminder Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
